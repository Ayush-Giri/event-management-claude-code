<%- include('../partials/header') %>

<div class="container">
  <div class="page-header">
    <div class="page-header-content">
      <h1>Upcoming Events</h1>
      <p class="page-header-subtitle"><%= events.length %> event<%= events.length !== 1 ? 's' : '' %> found</p>
    </div>
    <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
      <a href="/events/create" class="btn btn-primary">+ Create Event</a>
    <% } %>
  </div>

  <!-- Filter Section -->
  <section class="filter-section">
    <form method="GET" action="/events" class="form filter-form">
      <div class="filter-group">
        <div class="form-group">
          <label for="date" class="form-label">Date</label>
          <input
            type="date"
            id="date"
            name="date"
            class="form-control"
            value="<%= (typeof filters !== 'undefined' && filters.date) ? filters.date : '' %>"
          >
        </div>
        <div class="form-group">
          <label for="venue_id" class="form-label">Venue</label>
          <select id="venue_id" name="venue_id" class="form-control">
            <option value="">All Venues</option>
            <% if (typeof venues !== 'undefined' && venues) { %>
              <% venues.forEach(function(venue) { %>
                <option value="<%= venue.id %>" <%= (typeof filters !== 'undefined' && filters.venue_id && filters.venue_id == venue.id) ? 'selected' : '' %>><%= venue.name %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label for="activity_id" class="form-label">Activity</label>
          <select id="activity_id" name="activity_id" class="form-control">
            <option value="">All Activities</option>
            <% if (typeof activities !== 'undefined' && activities) { %>
              <% activities.forEach(function(activity) { %>
                <option value="<%= activity.id %>" <%= (typeof filters !== 'undefined' && filters.activity_id && filters.activity_id == activity.id) ? 'selected' : '' %>><%= activity.name %></option>
              <% }); %>
            <% } %>
          </select>
        </div>
        <div class="filter-actions">
          <button type="submit" class="btn btn-primary">Filter</button>
          <a href="/events" class="btn btn-secondary">Clear</a>
        </div>
      </div>
    </form>
  </section>

  <!-- Events Grid -->
  <% if (events.length > 0) { %>
    <section class="event-grid">
      <% events.forEach(function(event) { %>
        <article class="event-card card">
          <div class="event-card-body">
            <h3 class="event-card-title">
              <a href="/events/<%= event.id %>"><%= event.name %></a>
            </h3>
            <div class="event-card-meta">
              <span class="event-meta-item">
                <span class="meta-icon"></span>
                <%= new Date(event.date).toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
                <% if (event.time) { %>
                  at <%= event.time %>
                <% } %>
              </span>
              <% if (event.venue_names) { %>
                <span class="event-meta-item">
                  <span class="meta-icon"></span>
                  <%= event.venue_names %>
                </span>
              <% } %>
              <span class="event-meta-item">
                <span class="meta-icon"></span>
                <%= event.participant_count || 0 %> participant<%= (event.participant_count || 0) !== 1 ? 's' : '' %>
              </span>
            </div>
            <% if (event.activity_names) { %>
              <div class="event-card-tags">
                <% event.activity_names.split(',').forEach(function(activity) { %>
                  <span class="badge badge-activity"><%= activity.trim() %></span>
                <% }); %>
              </div>
            <% } %>
            <% if (event.description) { %>
              <p class="event-card-description">
                <%= event.description.length > 100 ? event.description.substring(0, 100) + '...' : event.description %>
              </p>
            <% } %>
          </div>
          <div class="event-card-footer">
            <a href="/events/<%= event.id %>" class="btn btn-secondary btn-sm">View Details</a>
          </div>
        </article>
      <% }); %>
    </section>
  <% } else { %>
    <section class="empty-state">
      <div class="empty-state-icon"></div>
      <h2 class="empty-state-title">No Events Found</h2>
      <p class="empty-state-text">There are no upcoming events matching your criteria. Try adjusting your filters or check back later!</p>
      <a href="/events" class="btn btn-primary">View All Events</a>
    </section>
  <% } %>
</div>

<%- include('../partials/footer') %>
