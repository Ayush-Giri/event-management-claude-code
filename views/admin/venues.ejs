<%- include('../partials/header') %>

<div class="container">
  <div class="page-header">
    <h1>Manage Venues</h1>
    <p class="page-header-subtitle"><%= venues.length %> venue<%= venues.length !== 1 ? 's' : '' %> available</p>
  </div>

  <section class="card form-section">
    <details class="collapsible-form" open>
      <summary class="collapsible-header">
        <h2 class="section-title">Add New Venue</h2>
      </summary>
      <form class="form" method="POST" action="/admin/venues" enctype="multipart/form-data">
        <div class="form-row">
          <div class="form-group">
            <label for="add-venue-name" class="form-label">Venue Name</label>
            <input
              type="text"
              id="add-venue-name"
              name="name"
              class="form-control"
              placeholder="Community Center Hall"
              required
            >
          </div>
          <div class="form-group">
            <label for="add-venue-address" class="form-label">Address</label>
            <input
              type="text"
              id="add-venue-address"
              name="address"
              class="form-control"
              placeholder="123 Main Street"
            >
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="add-venue-capacity" class="form-label">Capacity</label>
            <input
              type="number"
              id="add-venue-capacity"
              name="capacity"
              class="form-control"
              placeholder="100"
              min="1"
            >
          </div>
          <div class="form-group">
            <label for="add-venue-image" class="form-label">Image</label>
            <input type="file" id="add-venue-image" name="image" class="form-control" accept="image/*">
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Add Venue</button>
        </div>
      </form>
    </details>
  </section>

  <section class="card table-section">
    <% if (venues.length > 0) { %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Image</th>
              <th>Name</th>
              <th>Address</th>
              <th>Capacity</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% venues.forEach(function(venue) { %>
              <tr class="venue-row" id="venue-row-<%= venue.id %>">
                <td>
                  <% if (venue.image) { %>
                    <img src="/uploads/<%= venue.image %>" alt="<%= venue.name %>" class="table-thumbnail">
                  <% } else { %>
                    <span class="table-no-image">No image</span>
                  <% } %>
                </td>
                <td><strong><%= venue.name %></strong></td>
                <td><%= venue.address || '—' %></td>
                <td><%= venue.capacity || '—' %></td>
                <td class="table-actions">
                  <button type="button" class="btn btn-secondary btn-sm" onclick="toggleEditForm('venue-<%= venue.id %>')">Edit</button>
                  <% if (venue.image) { %>
                    <form class="form inline-form" method="POST" action="/admin/venues/<%= venue.id %>/remove-image">
                      <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Remove image?')">Remove Image</button>
                    </form>
                  <% } %>
                  <form class="form inline-form" method="POST" action="/admin/venues/<%= venue.id %>/delete">
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this venue?')">Delete</button>
                  </form>
                </td>
              </tr>

              <tr class="edit-row" id="edit-venue-<%= venue.id %>" style="display: none;">
                <td colspan="5">
                  <form class="form inline-edit-form" method="POST" action="/admin/venues/<%= venue.id %>/update" enctype="multipart/form-data">
                    <div class="form-row">
                      <div class="form-group">
                        <label class="form-label">Name</label>
                        <input type="text" name="name" class="form-control" value="<%= venue.name %>" required>
                      </div>
                      <div class="form-group">
                        <label class="form-label">Address</label>
                        <input type="text" name="address" class="form-control" value="<%= venue.address || '' %>">
                      </div>
                      <div class="form-group">
                        <label class="form-label">Capacity</label>
                        <input type="number" name="capacity" class="form-control" value="<%= venue.capacity || '' %>" min="1">
                      </div>
                      <div class="form-group">
                        <label class="form-label">New Image</label>
                        <input type="file" name="image" class="form-control" accept="image/*">
                      </div>
                      <div class="form-group form-actions-inline">
                        <button type="submit" class="btn btn-primary btn-sm">Save</button>
                        <button type="button" class="btn btn-secondary btn-sm" onclick="toggleEditForm('venue-<%= venue.id %>')">Cancel</button>
                      </div>
                    </div>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state empty-state-sm">
        <p class="text-muted">No venues added yet.</p>
      </div>
    <% } %>
  </section>
</div>

<script>
  function toggleEditForm(id) {
    var editRow = document.getElementById('edit-' + id);
    if (editRow) {
      editRow.style.display = editRow.style.display === 'none' ? 'table-row' : 'none';
    }
  }
</script>

<%- include('../partials/footer') %>
