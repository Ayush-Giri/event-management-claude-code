<%- include('../partials/header') %>

<div class="container">
  <div class="page-header">
    <h1>Manage Participants</h1>
    <p class="page-header-subtitle"><%= participants.length %> participant<%= participants.length !== 1 ? 's' : '' %> registered</p>
  </div>

  <!-- Add New Participant Form -->
  <section class="card form-section">
    <details class="collapsible-form" open>
      <summary class="collapsible-header">
        <h2 class="section-title">Add New Participant</h2>
      </summary>
      <form class="form" method="POST" action="/admin/participants">
        <div class="form-row">
          <div class="form-group">
            <label for="add-name" class="form-label">Full Name</label>
            <input
              type="text"
              id="add-name"
              name="name"
              class="form-control"
              placeholder="John Doe"
              required
            >
          </div>
          <div class="form-group">
            <label for="add-email" class="form-label">Email</label>
            <input
              type="email"
              id="add-email"
              name="email"
              class="form-control"
              placeholder="john@example.com"
              required
            >
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="add-phone" class="form-label">Phone</label>
            <input
              type="tel"
              id="add-phone"
              name="phone"
              class="form-control"
              placeholder="+1 (555) 000-0000"
            >
          </div>
          <div class="form-group">
            <label for="add-password" class="form-label">Password</label>
            <input
              type="password"
              id="add-password"
              name="password"
              class="form-control"
              placeholder="Minimum 6 characters"
              required
              minlength="6"
            >
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Add Participant</button>
        </div>
      </form>
    </details>
  </section>

  <!-- Participants Table -->
  <section class="card table-section">
    <% if (participants.length > 0) { %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% participants.forEach(function(participant) { %>
              <tr class="participant-row" id="participant-row-<%= participant.id %>">
                <td><strong><%= participant.name %></strong></td>
                <td><%= participant.email %></td>
                <td><%= participant.phone || '—' %></td>
                <td class="table-actions">
                  <button type="button" class="btn btn-secondary btn-sm" onclick="toggleEditForm('participant-<%= participant.id %>')">Edit</button>
                  <form class="form inline-form" method="POST" action="/admin/participants/<%= participant.id %>/delete">
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this participant?')">Delete</button>
                  </form>
                </td>
              </tr>
              <!-- Inline Edit Form (hidden by default) -->
              <tr class="edit-row" id="edit-participant-<%= participant.id %>" style="display: none;">
                <td colspan="4">
                  <form class="form inline-edit-form" method="POST" action="/admin/participants/<%= participant.id %>">
                    <div class="form-row">
                      <div class="form-group">
                        <label class="form-label">Name</label>
                        <input type="text" name="name" class="form-control" value="<%= participant.name %>" required>
                      </div>
                      <div class="form-group">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" value="<%= participant.email %>" required>
                      </div>
                      <div class="form-group">
                        <label class="form-label">Phone</label>
                        <input type="tel" name="phone" class="form-control" value="<%= participant.phone || '' %>">
                      </div>
                      <div class="form-group form-actions-inline">
                        <button type="submit" class="btn btn-primary btn-sm">Save</button>
                        <button type="button" class="btn btn-secondary btn-sm" onclick="toggleEditForm('participant-<%= participant.id %>')">Cancel</button>
                      </div>
                    </div>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state empty-state-sm">
        <p class="text-muted">No participants registered yet.</p>
      </div>
    <% } %>
  </section>
</div>

<script>
  function toggleEditForm(id) {
    var editRow = document.getElementById('edit-' + id);
    if (editRow) {
      editRow.style.display = editRow.style.display === 'none' ? 'table-row' : 'none';
    }
  }
</script>

<%- include('../partials/footer') %>
