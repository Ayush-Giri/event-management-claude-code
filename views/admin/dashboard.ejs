<%- include('../partials/header') %>

<div class="container">
  <div class="page-header">
    <h1>Admin Dashboard</h1>
    <p class="page-header-subtitle">Welcome back, <strong><%= user.name %></strong></p>
  </div>

  <section class="stats-grid">
    <div class="stat-card card">
      <div class="stat-icon"></div>
      <div class="stat-info">
        <span class="stat-value"><%= stats.eventCount %></span>
        <span class="stat-label">Total Events</span>
      </div>
    </div>
    <div class="stat-card card">
      <div class="stat-icon"></div>
      <div class="stat-info">
        <span class="stat-value"><%= stats.participantCount %></span>
        <span class="stat-label">Total Participants</span>
      </div>
    </div>
    <div class="stat-card card">
      <div class="stat-icon"></div>
      <div class="stat-info">
        <span class="stat-value"><%= stats.venueCount %></span>
        <span class="stat-label">Total Venues</span>
      </div>
    </div>
    <div class="stat-card card">
      <div class="stat-icon"></div>
      <div class="stat-info">
        <span class="stat-value"><%= stats.activityCount %></span>
        <span class="stat-label">Total Activities</span>
      </div>
    </div>
  </section>

  <section class="quick-actions">
    <h2 class="section-title">Quick Actions</h2>
    <div class="action-grid">
      <a href="/admin/participants" class="action-card card">
        <span class="action-icon"></span>
        <span class="action-text">Manage Participants</span>
      </a>
      <a href="/admin/venues" class="action-card card">
        <span class="action-icon"></span>
        <span class="action-text">Manage Venues</span>
      </a>
      <a href="/admin/activities" class="action-card card">
        <span class="action-icon"></span>
        <span class="action-text">Manage Activities</span>
      </a>
      <a href="/events/create" class="action-card card">
        <span class="action-icon"></span>
        <span class="action-text">Create New Event</span>
      </a>
    </div>
  </section>

  <section class="recent-events">
    <h2 class="section-title">Recent Events</h2>
    <% if (recentEvents && recentEvents.length > 0) { %>
      <div class="table-responsive">
        <table class="table">
          <thead>
            <tr>
              <th>Event Name</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% recentEvents.forEach(function(event) { %>
              <tr>
                <td><strong><%= event.name %></strong></td>
                <td><%= new Date(event.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %></td>
                <td>
                  <a href="/events/<%= event.id %>" class="btn btn-secondary btn-sm">View</a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="empty-state empty-state-sm">
        <p class="text-muted">No events created yet.</p>
        <a href="/events/create" class="btn btn-primary btn-sm">Create Your First Event</a>
      </div>
    <% } %>
  </section>
</div>

<%- include('../partials/footer') %>
